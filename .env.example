# Railway environment variables for latamsellers-api
# Copy to Railway project settings — file itself is never loaded.

# ── Postgres (Railway built-in) ──
# Shared with Next.js lsprofit-app (same DATABASE_URL on both services).
DATABASE_URL=postgres://user:pass@host:5432/dbname

# ── Mercado Livre OAuth ──
# Stored in table ml_app_config (set via /v2/ml-oauth/config endpoint).
# These env vars are only a fallback/bootstrap — the DB row takes priority.
ML_CLIENT_ID=your_app_id
ML_CLIENT_SECRET=your_secret_key

# ── Telegram Bot API ──
# Bot: latamsellersadm_bot. Same token as Next.js TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_TOKEN=your_bot_token

# ── Claude API (pt→ru translator for TG messages) ──
# Only used when a user sets notification_settings.language='ru'.
ANTHROPIC_API_KEY=sk-ant-your_key

# ── Cron cadence ──
# Interval between /communications/notices pulls. Default 30 min.
# Lower to 2 for end-to-end testing; raise in prod to respect ML rate limits.
NOTICES_SYNC_INTERVAL_MIN=30

# ── CORS ──
CORS_ORIGINS=https://app.lsprofit.app,https://phenolated-maleah-leonine.ngrok-free.dev
